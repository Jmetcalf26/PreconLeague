# --- Database ---
# When running with docker-compose, this points at the bundled Postgres service.
DATABASE_URL="postgresql://precon:precon@localhost:5432/precon?schema=public"

# --- Auth ---
# Secret used to sign session JWTs. Generate a strong one:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"

# --- Scryfall ---
# Scryfall asks API consumers to identify themselves. Customize this.
SCRYFALL_USER_AGENT="PreconLeague/1.0 (https://github.com/jmetcalf26/preconleague)"

# --- First admin ---
# The username below is granted admin rights automatically on registration.
# The very first account to register is always made admin regardless.
ADMIN_USERNAME="jack"
